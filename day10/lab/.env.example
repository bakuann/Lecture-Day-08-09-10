# Day 10 Lab — copy thành .env và điền key
#   cp .env.example .env   (Windows: copy .env.example .env)

# ChromaDB (tách collection khỏi Day 09)
CHROMA_DB_PATH=./chroma_db
CHROMA_COLLECTION=day10_kb

# Embedding qua Gemini API (KHÔNG tải model local — nhẹ máy)
#   Lấy API key tại: https://aistudio.google.com/apikey
GEMINI_API_KEY=
EMBEDDING_MODEL=gemini-embedding-001
# EMBEDDING_DIM=768          # tuỳ chọn rút chiều (gemini-embedding-001 hỗ trợ 128..3072)

# Freshness SLA (giờ) — monitoring/freshness_check.py
FRESHNESS_SLA_HOURS=24

# Rule-versioning (Distinction d): cutoff HR đọc từ contract; có thể override ở đây
# HR_LEAVE_MIN_EFFECTIVE_DATE=2026-01-01
